  "item": [
    {
      "name": "Obtener Categorías Raíz",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const lista = Array.isArray(json) ? json : (json._embedded ? Object.values(json._embedded)[0] : []);",
              "if (lista && lista.length && lista[0].id) pm.environment.set('id_categoria', lista[0].id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
